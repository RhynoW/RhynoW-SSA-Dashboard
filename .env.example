# ============================================================
# scenario04-advanced01 — Environment Variable Template
# Copy this file to .env and fill in your values.
# !! Never commit .env to version control !!
# ============================================================

# --- Database ---
# Path to the TLE DuckDB database (space_db_slim.duckdb or space_db.duckdb)
DB_PATH=./space_db_slim.duckdb

# --- Server ---
HOST=0.0.0.0
PORT=5011

# --- Conjunction Scan ---
# Proximity threshold in km for KD-tree scan
CONJ_THRESHOLD_KM=10.0
# Cache TTL in seconds (conjunction results are expensive to compute)
CONJ_TTL=120

# --- Cache ---
STATS_TTL=600

# --- Logging ---
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
