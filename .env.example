# ============================================================
# ATRDC_TLE_Tracker — Environment Variable Template
# Copy this file to .env and fill in your values.
# !! Never commit .env to version control !!
# ============================================================

# --- Flask Backend ---
# Secret key sent in X-API-Key header for all /api/* requests
BACKEND_API_KEY=change_me_to_a_random_secret

# --- Cesium ION (scenario2.py) ---
# 免費申請：https://ion.cesium.com/tokens
# 未設定時 scenario2.py 改用 OpenStreetMap 圖磚（功能仍正常）
CESIUM_ION_TOKEN=

# --- Space-Track Credentials (https://www.space-track.org) ---
SPACE_TRACK_IDENTITY=your_email@example.com
SPACE_TRACK_PASSWORD=your_password

# --- Database Paths ---
SPACE_DB_PATH=./space_db.duckdb
SLIM_DB_PATH=./space_db_slim.duckdb
SPACE_DB_PATH_TLE_RAW=./space_db_tle_raw.duckdb

# --- SSA Dashboard (scenario04-advanced01/02.py) ---
# slim DB 在執行 sync_slim_db_recent_tle() 後已補入近 30 天 line1/line2，可直接使用
DB_PATH=./space_db_slim.duckdb
# 近距離掃描閾值 (km)
CONJ_THRESHOLD_KM=10.0
# 統計快取存活秒數
STATS_TTL=600

# --- TLE Download Directories ---
DAILY_TLE_TEMP_PATH=./tle_downloads_temp
DAILY_TLE_PATH=./tle_downloads

# --- Last Processed Dates (auto-updated by download_tle_unified.py) ---
LAST_TLE_DATE=2024-01-01
LAST_TLE_DATE_TEL_RAW=2024-01-01
